---
import { CV_URL, GITHUB_URL, LINKEDIN_URL } from '../../constants/urls';

const currentYear = new Date().getFullYear();
---

<footer>
  <div class="footer-inner">
    <div class="footer-left">
      <a href="#hero" class="footer-logo">
        <img src="/logo_N.png" alt="Nico Hermida" />
        <span>nicohermida</span>
      </a>
      <p class="footer-copy">
        © {currentYear} Nico Hermida. All rights reserved.
      </p>
    </div>

    <div class="footer-right">
      <a href={GITHUB_URL} target="_blank" class="footer-link">
        GitHub
      </a>
      <a href={LINKEDIN_URL} target="_blank" class="footer-link">
        LinkedIn
      </a>
      <a href={CV_URL} target="_blank" class="footer-link">
        CV
      </a>
    </div>
  </div>

  <div class="footer-bottom">
    <span>Built with</span>
    <span class="footer-tech">Astro</span>
    <span>·</span>
    <span class="footer-tech">TailwindCSS</span>
    <span>·</span>
    <span>Deployed on</span>
    <span class="footer-tech">Vercel</span>
  </div>
</footer>

<style>
  footer {
    position: relative;
    z-index: 2;
    border-top: 1px solid var(--border);
    padding: 40px 60px 32px;
    max-width: 1100px;
    margin: 0 auto;
  }

  .footer-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 28px;
    flex-wrap: wrap;
    gap: 24px;
  }

  /* Left */
  .footer-left {
    display: flex;
    flex-direction: column;
    gap: 10px;
  }

  .footer-logo {
    display: flex;
    align-items: center;
    gap: 10px;
    text-decoration: none;
  }

  .footer-logo img {
    width: 28px;
    height: 28px;
    object-fit: contain;
  }

  .footer-logo span {
    font-size: 14px;
    font-weight: 600;
    color: var(--text);
    letter-spacing: -0.01em;
  }

  .footer-copy {
    font-size: 12px;
    color: rgba(255, 255, 255, 0.2);
    font-family: var(--mono);
  }

  /* Right */
  .footer-right {
    display: flex;
    align-items: center;
    gap: 28px;
  }

  .footer-link {
    font-size: 13px;
    font-weight: 500;
    color: var(--muted);
    text-decoration: none;
    transition: color 0.2s;
  }

  .footer-link:hover {
    color: var(--text);
  }

  /* Bottom */
  .footer-bottom {
    display: flex;
    align-items: center;
    gap: 6px;
    font-size: 12px;
    font-family: var(--mono);
    color: rgba(255, 255, 255, 0.15);
    border-top: 1px solid var(--border);
    padding-top: 24px;
  }

  .footer-tech {
    background: linear-gradient(135deg, var(--blue), var(--cyan));
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    font-weight: 600;
  }

  /* Responsive */
  @media (max-width: 768px) {
    footer {
      padding: 40px 24px 32px;
    }

    .footer-inner {
      flex-direction: column;
      align-items: flex-start;
      gap: 20px;
    }

    .footer-right {
      gap: 20px;
    }

    .footer-bottom {
      flex-wrap: wrap;
    }
  }
</style>