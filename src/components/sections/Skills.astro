---
import { skills } from '../../data/skills';
---

<section id="skills" class="fade-up">
  <div class="section-tag">Skills</div>
  <h2 class="section-title">Stack técnico</h2>

  <div class="skills-grid">
    {skills.map((group) => (
      <div class="skill-group">
        <div class="skill-group-title">{group.category}</div>
        <div class="skill-items">
          {group.items.map((item) => (
            <span class="skill-item">{item}</span>
          ))}
        </div>
      </div>
    ))}
  </div>
</section>

<style>
  #skills {
    max-width: 1100px;
    margin: 0 auto;
    padding: 120px 60px;
    position: relative;
    z-index: 2;
  }

  .section-title {
    font-size: 42px;
    font-weight: 700;
    letter-spacing: -0.03em;
    line-height: 1.1;
    margin-bottom: 48px;
    color: var(--text);
  }

  .skills-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 16px;
  }

  .skill-group {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 16px;
    padding: 28px 30px;
    backdrop-filter: blur(10px);
    transition: border-color 0.2s;
  }

  .skill-group:hover {
    border-color: rgba(37, 99, 240, 0.25);
  }

  .skill-group-title {
    font-family: var(--mono);
    font-size: 12px;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    color: var(--cyan);
    margin-bottom: 18px;
    opacity: 0.8;
  }

  .skill-items {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
  }

  .skill-item {
    font-size: 14px;
    font-weight: 500;
    color: var(--text);
    background: rgba(255, 255, 255, 0.05);
    border: 1px solid rgba(255, 255, 255, 0.08);
    padding: 6px 14px;
    border-radius: 8px;
    transition: background 0.2s, border-color 0.2s, color 0.2s;
  }

  .skill-item:hover {
    background: rgba(37, 99, 240, 0.12);
    border-color: rgba(37, 99, 240, 0.3);
    color: #fff;
  }

  /* Responsive */
  @media (max-width: 768px) {
    #skills {
      padding: 80px 24px;
    }

    .section-title {
      font-size: 32px;
      margin-bottom: 32px;
    }

    .skills-grid {
      grid-template-columns: 1fr;
    }
  }
</style>