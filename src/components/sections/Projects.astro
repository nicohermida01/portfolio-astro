---
import { projects } from '../../data/projects';
---

<section id="projects" class="fade-up">
  <div class="section-tag">Projects</div>
  <h2 class="section-title">Projects</h2>

  <div class="projects-list">
    {projects.map((project, i) => (
      <div class={`project-card ${project.featured ? 'featured' : ''}`}>

        {project.image && (
          <div class="project-image-wrap" data-index={i}>
            <img
              src={project.image}
              alt={project.name}
              class="project-image"
              loading="lazy"
            />
            <div class="project-image-overlay">
              <span class="zoom-icon">⤢ View image</span>
            </div>
          </div>
        )}

        <div class="project-body">
          <div class="project-header">
            <span class="project-name">{project.name}</span>
            {project.badge && (
              <span class={`project-badge badge-${project.badge.type}`}>
                {project.badge.label}
              </span>
            )}
          </div>

          <p class="project-desc">{project.description}</p>

          <div class="project-footer">
            <div class="tech-tags">
              {project.stack.map((tech) => (
                <span class="tech-tag">{tech}</span>
              ))}
            </div>

            <div class="project-links">
              {project.repoUrl && (
                <a href={project.repoUrl} target="_blank" class="project-link primary">
                  GitHub ↗
                </a>
              )}
              {project.liveUrl && (
                <a href={project.liveUrl} target="_blank" class="project-link">
                  Live ↗
                </a>
              )}
              {!project.repoUrl && !project.liveUrl && (
                <span class="project-link disabled">
                  {project.repoPrivate ? 'Private repo' : 'Coming soon'}
                </span>
              )}
            </div>
          </div>
        </div>

      </div>
    ))}
  </div>
</section>

<!-- Lightbox -->
<div id="lightbox" class="lightbox">
  <button class="lightbox-close" id="lightbox-close">✕</button>
  <img id="lightbox-img" src="" alt="" class="lightbox-image" />
</div>

<style>
  #projects {
    max-width: 1100px;
    margin: 0 auto;
    padding: 120px 60px;
    position: relative;
    z-index: 2;
  }

  .section-title {
    font-size: 42px;
    font-weight: 700;
    letter-spacing: -0.03em;
    line-height: 1.1;
    margin-bottom: 48px;
    color: var(--text);
  }

  .projects-list {
    display: flex;
    flex-direction: column;
    gap: 20px;
  }

  /* Card */
  .project-card {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 20px;
    overflow: hidden;
    backdrop-filter: blur(10px);
    transition: border-color 0.3s, transform 0.3s;
  }

  .project-card:hover {
    border-color: rgba(37, 99, 240, 0.35);
    transform: translateY(-2px);
  }

  .project-card.featured {
    background: linear-gradient(
      135deg,
      rgba(37, 99, 240, 0.06),
      rgba(62, 255, 192, 0.03)
    );
    border-color: rgba(37, 99, 240, 0.2);
  }

  .project-card.featured:hover {
    border-color: rgba(37, 99, 240, 0.5);
  }

  /* Image */
  .project-image-wrap {
    position: relative;
    width: 100%;
    height: 280px;
    overflow: hidden;
    border-bottom: 1px solid var(--border);
  }

  .project-image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: top;
    transition: transform 0.5s ease;
    display: block;
  }

  .project-image-wrap:hover .project-image {
    transform: scale(1.03);
  }

  .project-image-overlay {
    position: absolute;
    inset: 0;
    background: rgba(6, 8, 16, 0.5);
    display: flex;
    align-items: center;
    justify-content: center;
    opacity: 0;
    transition: opacity 0.3s;
  }

  .project-image-wrap:hover .project-image-overlay {
    opacity: 1;
  }

  .zoom-icon {
    font-size: 14px;
    font-weight: 600;
    color: #fff;
    background: rgba(37, 99, 240, 0.7);
    border: 1px solid rgba(37, 99, 240, 0.5);
    padding: 10px 20px;
    border-radius: 10px;
    backdrop-filter: blur(8px);
    letter-spacing: 0.02em;
  }

  /* Body */
  .project-body {
    padding: 32px 36px;
  }

  .project-header {
    display: flex;
    align-items: center;
    gap: 12px;
    margin-bottom: 14px;
    flex-wrap: wrap;
  }

  .project-name {
    font-size: 20px;
    font-weight: 700;
    letter-spacing: -0.02em;
    color: var(--text);
  }

  .project-badge {
    font-family: var(--mono);
    font-size: 12px;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    padding: 3px 10px;
    border-radius: 100px;
    white-space: nowrap;
  }

  .badge-wip {
    background: rgba(251, 191, 36, 0.1);
    border: 1px solid rgba(251, 191, 36, 0.3);
    color: #fbbf24;
  }

  .badge-university {
    background: rgba(62, 255, 192, 0.08);
    border: 1px solid rgba(62, 255, 192, 0.2);
    color: var(--cyan);
  }

  .badge-personal {
    background: rgba(37, 99, 240, 0.08);
    border: 1px solid rgba(37, 99, 240, 0.2);
    color: var(--blue);
  }

  .project-desc {
    font-size: 14px;
    color: var(--muted);
    line-height: 1.7;
    margin-bottom: 24px;
    max-width: 720px;
  }

  .project-footer {
    display: flex;
    align-items: center;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 16px;
  }

  .project-links {
    display: flex;
    gap: 10px;
    align-items: center;
    flex-shrink: 0;
  }

  .project-link {
    font-size: 12px;
    font-weight: 500;
    text-decoration: none;
    display: inline-flex;
    align-items: center;
    gap: 6px;
    padding: 8px 16px;
    border-radius: 8px;
    border: 1px solid var(--border);
    color: var(--muted);
    white-space: nowrap;
    transition: border-color 0.2s, color 0.2s, background 0.2s;
  }

  .project-link:hover {
    border-color: rgba(255, 255, 255, 0.2);
    color: var(--text);
    background: rgba(255, 255, 255, 0.04);
  }

  .project-link.primary {
    border-color: rgba(37, 99, 240, 0.4);
    color: var(--blue);
    background: rgba(37, 99, 240, 0.08);
  }

  .project-link.primary:hover {
    background: rgba(37, 99, 240, 0.18);
    border-color: var(--blue);
  }

  .project-link.disabled {
    opacity: 0.7;
    font-size: 12px;
    pointer-events: none;
  }

  /* Lightbox */
  .lightbox {
    position: fixed;
    inset: 0;
    background: rgba(6, 8, 16, 0.95);
    z-index: 1000;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 40px;
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.3s;
    backdrop-filter: blur(12px);
  }

  .lightbox.open {
    opacity: 1;
    pointer-events: all;
  }

  .lightbox-image {
    max-width: 100%;
    max-height: 90vh;
    border-radius: 12px;
    border: 1px solid var(--border);
    box-shadow: 0 24px 80px rgba(0, 0, 0, 0.6);
    object-fit: contain;
  }

  .lightbox-close {
    position: absolute;
    top: 24px;
    right: 28px;
    background: rgba(255, 255, 255, 0.08);
    border: 1px solid var(--border);
    color: var(--text);
    font-size: 16px;
    width: 40px;
    height: 40px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: background 0.2s;
  }

  .lightbox-close:hover {
    background: rgba(255, 255, 255, 0.15);
  }

  /* Responsive */
  @media (max-width: 768px) {
    #projects {
      padding: 80px 24px;
    }

    .section-title {
      font-size: 32px;
      margin-bottom: 32px;
    }

    .project-image-wrap {
      height: 200px;
    }

    .project-body {
      padding: 24px 20px;
    }

    .project-name {
      font-size: 18px;
    }

    .project-footer {
      flex-direction: column;
      align-items: flex-start;
    }
  }
</style>

<script>
  const lightbox = document.getElementById('lightbox');
  const lightboxImg = document.getElementById('lightbox-img') as HTMLImageElement;
  const lightboxClose = document.getElementById('lightbox-close');

  // Abrir lightbox al clickear imagen
  document.querySelectorAll('.project-image-wrap').forEach((wrap) => {
    wrap.addEventListener('click', () => {
      const img = wrap.querySelector('.project-image') as HTMLImageElement;
      if (img && lightboxImg && lightbox) {
        lightboxImg.src = img.src;
        lightboxImg.alt = img.alt;
        lightbox.classList.add('open');
        document.body.style.overflow = 'hidden';
      }
    });
  });

  // Cerrar con botón
  lightboxClose?.addEventListener('click', closeLightbox);

  // Cerrar clickeando el fondo
  lightbox?.addEventListener('click', (e) => {
    if (e.target === lightbox) closeLightbox();
  });

  // Cerrar con Escape
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape') closeLightbox();
  });

  function closeLightbox() {
    lightbox?.classList.remove('open');
    document.body.style.overflow = '';
  }
</script>