---
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'Nico Hermida — Fullstack Developer',
  description = 'Desarrollador fullstack especializado en arquitecturas web modernas. NestJS, Next.js, FastAPI, React Native.',
} = Astro.props;
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="author" content="Nico Hermida" />
    <link rel="icon" type="image/png" href="/logo_N.png" />
    <title>{title}</title>
  </head>
  <body>
    <slot />
  </body>
</html>